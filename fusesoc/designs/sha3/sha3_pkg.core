name: hash:sha3:pkg:0.1.0
description: Shake128/256 definitions

filesets:
  pkg:
    depend:
      - cross:pkg:common_pkg
    files:
      - rtl/sha3_pkg.sv
    file_type: systemVerilogSource
  lint_verilator:
    files:
      - lint/sha3_pkg.vlt: { file_type: vlt }

targets:
  default: &default
    filesets:
      - tool_verilator ? (lint_verilator)
      - pkg
